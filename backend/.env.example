# ============================================================
# CONFIGURACION DEL SERVIDOR BACKEND FASTIFY
# ============================================================
PORT=3001
HOST=0.0.0.0

# Autenticación JWT
JWT_SECRET="your_jwt_secret_key_here"

# ============================================================
# CONFIGURACION DEL BROKER MQTT
# ============================================================
MQTT_BROKER=mqtt://localhost
MQTT_PORT=1883
MQTT_USER=
MQTT_PASS=

# ============================================================
# CONFIGURACION DE BASE DE DATOS (Persistencia Relacional / Dual)
# ============================================================
# DB_MODE: 'local' | 'supabase' | 'prisma'
DB_MODE=local

# Credenciales de Supabase
SUPABASE_URL=
SUPABASE_KEY=

# URL de Conexión de Prisma PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/smart_containers?schema=public"

# ============================================================
# CONFIGURACION DE SERIES TEMPORALES (InfluxDB)
# ============================================================
INFLUX_URL=
INFLUX_TOKEN=
INFLUX_ORG=
INFLUX_BUCKET=
