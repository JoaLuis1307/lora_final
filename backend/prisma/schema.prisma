datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model MapPoint {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(255)
  latitude    Float
  longitude   Float
  type        String   @db.VarChar(50)
  description String?  @db.Text
  created_at  DateTime @default(now()) @db.Timestamptz
  devices     Device[]

  @@map("map_points")
}

model Device {
  id              Int       @id @default(autoincrement())
  device_id       String    @unique @db.VarChar(50)
  name            String    @db.VarChar(255)
  type            String    @db.VarChar(50)
  status          String    @default("Configuring") @db.VarChar(20)
  latitude        Float
  longitude       Float
  battery_level   Int       @default(100)
  signal_strength Int       @default(-50)
  last_seen       DateTime? @db.Timestamptz
  mac_address     String?   @unique @db.VarChar(30)
  registered      Boolean   @default(true)
  map_point_id    Int?
  map_point       MapPoint? @relation(fields: [map_point_id], references: [id], onDelete: SetNull)
  gateway_id      String?   @db.VarChar(50)

  @@map("devices")
}

model Telemetry {
  id            Int      @id @default(autoincrement())
  device_id     String   @db.VarChar(50)
  sequence      Int
  temperature   Float
  humidity      Float
  air_quality   Int
  ultrasonic_cm Float
  tof_cm        Float
  obstacle      Int      @default(0)
  altitude      Float
  satellites    Int
  rssi          Int
  snr           Float
  pkts          Int
  crc_ok        Int      @default(1)
  crc_err       Int      @default(0)
  battery               Float    @default(0)
  battery_pct           Float    @default(0)
  batt_current_ma       Float    @default(0)
  batt_power_mw         Float    @default(0)
  batt_remaining_mah    Float    @default(0)
  batt_consumed_mah     Float    @default(0)
  batt_runtime_min      Float    @default(0)
  batt_energy_consumed_mwh Float @default(0)
  batt_energy_total_mwh    Float @default(0)
  batt_low               Int    @default(0)
  batt_critical          Int    @default(0)
  timestamp     DateTime @default(now()) @db.Timestamptz

  @@index([device_id, timestamp(sort: Desc)], name: "idx_telemetry_device_timestamp")
  @@map("telemetry")
}

model Route {
  id         Int      @id @default(autoincrement())
  name       String   @db.VarChar(255)
  district   String   @db.VarChar(100)
  points     Json
  distance   Float
  duration   Int
  color      String   @default("#2dd4bf") @db.VarChar(10)
  created_at DateTime @default(now()) @db.Timestamptz

  @@map("routes")
}

model User {
  id         Int      @id @default(autoincrement())
  email      String   @unique @db.VarChar(255)
  name       String?  @db.VarChar(255)
  password   String   @db.VarChar(255)
  created_at DateTime @default(now()) @db.Timestamptz

  @@map("users")
}

// ==========================================
// VEHICLE FLEET MANAGEMENT SYSTEM MODELS
// ==========================================

model Vehicle {
  id          String   @id @db.VarChar(50)             // E.g. "T-101", "T-102"
  plate       String   @unique @db.VarChar(30)         // E.g. "BC-1234"
  driver      String   @db.VarChar(255)                // E.g. "Juan Pérez"
  status      String   @default("Available") @db.VarChar(50) // 'In Route' | 'Maintenance' | 'Available' | 'Low Fuel'
  fuel        Float    @default(100)                   // Percentage
  capacity    Float    @default(0)                     // Percentage
  location    String   @db.VarChar(255)                // E.g. "Av. Ejercito, 402"
  last_update String   @db.VarChar(100)                // E.g. "Hace 2 min"
  speed       Float    @default(0)                     // km/h
  created_at  DateTime @default(now()) @db.Timestamptz

  maintenance_logs MaintenanceLog[]

  @@map("vehicles")
}

model MaintenanceLog {
  id          Int      @id @default(autoincrement())
  vehicle_id  String   @db.VarChar(50)
  vehicle     Vehicle  @relation(fields: [vehicle_id], references: [id], onDelete: Cascade)
  description String   @db.Text
  cost        Float    @default(0)
  severity    String   @default("warning") @db.VarChar(20) // 'error' | 'warning' | 'info'
  date        DateTime @default(now()) @db.Timestamptz
  created_at  DateTime @default(now()) @db.Timestamptz

  @@map("maintenance_logs")
}
